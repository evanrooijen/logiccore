{
  "$schema": "./node_modules/turbo/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DB_FILE_NAME",
    "SPACETIMEDB_HOST",
    "SPACETIMEDB_DB_NAME",
    "NEXT_PUBLIC_SPACETIMEDB_HOST",
    "NEXT_PUBLIC_SPACETIMEDB_DB_NAME"
  ],
  "tasks": {
    "//#fix": {},
    "//#check": {},
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/*"]
    },
    "@logiccore/web#build": {
      "dependsOn": ["@logiccore/spacetimedb#db:generate", "^build"],
      "outputs": [".next/*"]
    },
    "@logiccore/spacetimedb#build": {
      "cache": false,
      "outputs": []
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "test": {}
  }
}
